<Page x:Class="_3isip_423_Kalachev_Zhalyuk.Page3"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:local="clr-namespace:_3isip_423_Kalachev_Zhalyuk"
      xmlns:wf="clr-namespace:System.Windows.Forms;assembly=System.Windows.Forms"
      xmlns:charts="clr-namespace:System.Windows.Forms.DataVisualization.Charting;assembly=System.Windows.Forms.DataVisualization"
      mc:Ignorable="d" 
      d:DesignHeight="450" d:DesignWidth="800"
      Title="Page3">
    <ScrollViewer>
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>
            <Image Source="function3.png" Height="100" Grid.Row="0" ToolTip="Скриншот функции"/>
            <Label Content="x0:" Grid.Row="1"/>
            <TextBox x:Name="tbX0" Grid.Row="1" Margin="50,0,0,0" ToolTip="Начальное x"/>
            <Label Content="xk:" Grid.Row="2"/>
            <TextBox x:Name="tbXk" Grid.Row="2" Margin="50,0,0,0" ToolTip="Конечное x"/>
            <Label Content="dx:" Grid.Row="3"/>
            <TextBox x:Name="tbDx" Grid.Row="3" Margin="50,0,0,0" ToolTip="Шаг dx"/>
            <Label Content="b:" Grid.Row="4"/>
            <TextBox x:Name="tbB" Grid.Row="4" Margin="50,0,0,0" ToolTip="Значение b"/>
            <Label Content="Результаты:" Grid.Row="5"/>
            <TextBox x:Name="tbResults" Grid.Row="5" Margin="100,0,0,0" Height="100" AcceptsReturn="True" IsReadOnly="True" ToolTip="Список значений"/>
            <WindowsFormsHost Grid.Row="7" MinHeight="200" ToolTip="График y(x)">
                <charts:Chart x:Name="ChartFunction">
                    <charts:Chart.Legends>
                        <charts:Legend />
                    </charts:Chart.Legends>
                </charts:Chart>
            </WindowsFormsHost>
            <Button Content="Вычислить" Grid.Row="8" Click="Calculate_Click" ToolTip="Вычислить значения"/>
            <Button Content="Очистить" Grid.Row="8" Margin="100,0,0,0" Click="Clear_Click" ToolTip="Очистить поля"/>
        </Grid>
    </ScrollViewer>
</Page>

